# URL da aplicação rodando (local, staging ou preview do Vercel)
BASE_URL=http://localhost:3000

# Contas DEDICADAS de teste — NUNCA reutilize contas reais (fotografo3@, cliente3@ etc.)
# Crie essas duas contas uma vez no Supabase Auth e deixe só para a suíte E2E usar.
TEST_PHOTOGRAPHER_EMAIL=fotografo.e2e@fotoevento.test
TEST_PHOTOGRAPHER_PASSWORD=

TEST_CLIENT_EMAIL=cliente.e2e@fotoevento.test
TEST_CLIENT_PASSWORD=

# Opcional: ID de um evento que pertence a OUTRO fotógrafo, usado no teste
# negativo de "não pode acessar evento alheio". Se não definir, esse teste é pulado.
TEST_OTHER_PHOTOGRAPHER_EVENT_ID=

# Supabase — service role key usada SOMENTE em Node (global-setup/teardown),
# nunca é exposta ao browser. Pegue em Project Settings > API no Supabase.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
